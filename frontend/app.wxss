/* ==============================
   口袋小精灵 - 双主题 UI 系统
   遵循 Apple Human Interface Guidelines
   ============================== */

/* ==================== 暗色主题（默认） ==================== */
page {
  /* 主色系 */
  --primary-color: #6366f1;
  --primary-light: #818cf8;
  --primary-dark: #4f46e5;
  --secondary-color: #ec4899;
  --accent-color: #06b6d4;

  /* 语义色 */
  --success-color: #10b981;
  --warning-color: #f59e0b;
  --danger-color: #ef4444;

  /* 背景色 */
  --bg-primary: #0f0f23;
  --bg-secondary: #1a1a2e;
  --bg-card: rgba(30, 30, 60, 0.8);
  --bg-glass: rgba(255, 255, 255, 0.05);
  --bg-input: rgba(30, 30, 60, 0.6);

  /* 文字色 */
  --text-primary: #ffffff;
  --text-secondary: #a1a1aa;
  --text-muted: #71717a;
  --text-on-primary: #ffffff;

  /* 边框与阴影 */
  --border-color: rgba(99, 102, 241, 0.3);
  --border-light: rgba(99, 102, 241, 0.15);
  --shadow-color: rgba(0, 0, 0, 0.3);
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  --shadow-button: 0 2rpx 12rpx rgba(99, 102, 241, 0.3);

  /* 图标渐变色（高饱和度）*/
  --icon-bg-primary: linear-gradient(135deg, #6366f1, #818cf8);
  --icon-bg-secondary: linear-gradient(135deg, #ec4899, #f472b6);
  --icon-bg-success: linear-gradient(135deg, #10b981, #34d399);
  --icon-bg-warning: linear-gradient(135deg, #f59e0b, #fbbf24);
  --icon-bg-accent: linear-gradient(135deg, #06b6d4, #22d3ee);
  --icon-bg-danger: linear-gradient(135deg, #ef4444, #f87171);

  /* 按钮配色 */
  --button-primary-bg: #6366f1;
  --button-primary-text: #ffffff;
  --button-secondary-bg: rgba(255, 255, 255, 0.1);
  --button-secondary-text: #a1a1aa;
  --button-danger-bg: rgba(239, 68, 68, 0.15);
  --button-danger-text: #ef4444;

  /* 卡片状态 */
  --card-active-bg: rgba(99, 102, 241, 0.15);
  --card-hover-bg: rgba(99, 102, 241, 0.1);

  /* 输入框焦点 */
  --input-focus-border: rgba(99, 102, 241, 0.5);
  --input-focus-shadow: 0 0 0 3rpx rgba(99, 102, 241, 0.2);

  /* 导航栏 */
  --nav-bg: #0f0f23;
  --nav-text: #ffffff;

  /* TabBar */
  --tabbar-bg: #0f0f23;
  --tabbar-color: #71717a;
  --tabbar-active: #6366f1;

  /* 装饰渐变 */
  --gradient-shape-1: rgba(99, 102, 241, 0.15);
  --gradient-shape-2: rgba(236, 72, 153, 0.1);

  /* 主题切换过渡 */
  transition: background 0.3s ease, color 0.3s ease;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* ==================== 亮色主题（Apple 风格） ==================== */
page.theme-light,
.page.theme-light {
  /* 主色系（品牌色保持一致）*/
  --primary-color: #6366f1;
  --primary-light: #818cf8;
  --primary-dark: #4f46e5;
  --secondary-color: #ec4899;
  --accent-color: #06b6d4;

  /* 语义色 */
  --success-color: #10b981;
  --warning-color: #f59e0b;
  --danger-color: #ef4444;

  /* 背景色系统（Apple 层次感）*/
  --bg-primary: #F2F2F7;
  --bg-secondary: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-glass: rgba(0, 0, 0, 0.02);
  --bg-input: #E5E5EA;

  /* 文字色系统 */
  --text-primary: #1C1C1E;
  --text-secondary: #3C3C43;
  --text-muted: #8E8E93;
  --text-on-primary: #FFFFFF;

  /* 边框与阴影 */
  --border-color: rgba(60, 60, 67, 0.12);
  --border-light: rgba(60, 60, 67, 0.06);
  --shadow-color: rgba(0, 0, 0, 0.08);
  --shadow-card: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-button: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);

  /* 图标渐变色（粉彩系列）*/
  --icon-bg-primary: linear-gradient(135deg, #A5B4FC, #C7D2FE);
  --icon-bg-secondary: linear-gradient(135deg, #F9A8D4, #FBCFE8);
  --icon-bg-success: linear-gradient(135deg, #86EFAC, #BBF7D0);
  --icon-bg-warning: linear-gradient(135deg, #FCD34D, #FDE68A);
  --icon-bg-accent: linear-gradient(135deg, #67E8F9, #A5F3FC);
  --icon-bg-danger: linear-gradient(135deg, #FCA5A5, #FECACA);

  /* 按钮配色 */
  --button-primary-bg: #6366f1;
  --button-primary-text: #ffffff;
  --button-secondary-bg: #E5E5EA;
  --button-secondary-text: #3C3C43;
  --button-danger-bg: #FEE2E2;
  --button-danger-text: #EF4444;

  /* 卡片状态 */
  --card-active-bg: rgba(99, 102, 241, 0.08);
  --card-hover-bg: rgba(99, 102, 241, 0.04);

  /* 输入框焦点 */
  --input-focus-border: rgba(99, 102, 241, 0.4);
  --input-focus-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);

  /* 导航栏 */
  --nav-bg: #FFFFFF;
  --nav-text: #1C1C1E;

  /* TabBar */
  --tabbar-bg: #FFFFFF;
  --tabbar-color: #8E8E93;
  --tabbar-active: #6366f1;

  /* 装饰渐变（极淡）*/
  --gradient-shape-1: rgba(99, 102, 241, 0.03);
  --gradient-shape-2: rgba(236, 72, 153, 0.02);
}

/* 全局背景装饰 */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 80%, var(--gradient-shape-1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, var(--gradient-shape-2) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
}

/* ==================== 动画关键帧 ==================== */

/* 基础动画 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInLeft {
  from { opacity: 0; transform: translateX(-40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes fadeInRight {
  from { opacity: 0; transform: translateX(40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slideInUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes slideInDown {
  from { transform: translateY(-100%); }
  to { transform: translateY(0); }
}

/* 循环动画 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 10px rgba(99, 102, 241, 0.5); }
  50% { box-shadow: 0 0 25px rgba(99, 102, 241, 0.8); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.05); opacity: 0.8; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes gradientMove {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  25% { transform: translateY(-8rpx); }
  50% { transform: translateY(0); }
  75% { transform: translateY(-4rpx); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  50% { transform: translateX(8rpx); }
  75% { transform: translateX(-4rpx); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 波纹效果 */
@keyframes ripple {
  0% { transform: scale(0); opacity: 0.6; }
  100% { transform: scale(4); opacity: 0; }
}

/* 骨架屏动画 */
@keyframes skeleton {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ==================== 动画工具类 ==================== */

/* 入场动画 */
.fade-in-up { animation: fadeInUp 0.5s ease-out forwards; opacity: 0; }
.fade-in-down { animation: fadeInDown 0.5s ease-out forwards; opacity: 0; }
.fade-in-left { animation: fadeInLeft 0.5s ease-out forwards; opacity: 0; }
.fade-in-right { animation: fadeInRight 0.5s ease-out forwards; opacity: 0; }
.fade-in { animation: fadeIn 0.4s ease-out forwards; opacity: 0; }
.scale-in { animation: scaleIn 0.4s ease-out forwards; opacity: 0; }
.slide-in-up { animation: slideInUp 0.4s ease-out forwards; }
.slide-in-down { animation: slideInDown 0.4s ease-out forwards; }

/* 循环动画 */
.float-animation { animation: float 3s ease-in-out infinite; }
.glow-animation { animation: glow 2s ease-in-out infinite; }
.pulse-animation { animation: pulse 2s ease-in-out infinite; }
.bounce-animation { animation: bounce 1s ease-in-out infinite; }
.rotate-animation { animation: rotate 2s linear infinite; }

/* 动画延迟 */
.anim-delay-1 { animation-delay: 0.1s !important; }
.anim-delay-2 { animation-delay: 0.2s !important; }
.anim-delay-3 { animation-delay: 0.3s !important; }
.anim-delay-4 { animation-delay: 0.4s !important; }
.anim-delay-5 { animation-delay: 0.5s !important; }
.anim-delay-6 { animation-delay: 0.6s !important; }
.anim-delay-7 { animation-delay: 0.7s !important; }
.anim-delay-8 { animation-delay: 0.8s !important; }

/* 列表项交错动画（通过 style 设置 animation-delay）*/
.list-item-anim {
  animation: fadeInUp 0.5s ease-out forwards;
  opacity: 0;
}

/* 交互反馈 */
.tap-scale {
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.tap-scale:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.tap-opacity {
  transition: opacity 0.15s ease;
}

.tap-opacity:active {
  opacity: 0.7;
}

.tap-bg {
  transition: background-color 0.15s ease;
}

.tap-bg:active {
  background-color: var(--card-active-bg);
}

/* 卡片悬浮效果 */
.card-hover {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card-hover:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

/* 按钮波纹容器 */
.ripple-container {
  position: relative;
  overflow: hidden;
}

.ripple {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  animation: ripple 0.6s ease-out forwards;
  pointer-events: none;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, var(--bg-secondary) 25%, var(--bg-input) 50%, var(--bg-secondary) 75%);
  background-size: 200% 100%;
  animation: skeleton 1.5s ease-in-out infinite;
}

/* 页面过渡容器 */
.page-enter {
  animation: fadeIn 0.3s ease-out forwards;
}

.page-slide-enter {
  animation: slideInUp 0.3s ease-out forwards;
}

/* 列表容器动画 */
.list-container > view:nth-child(1) { animation-delay: 0.05s; }
.list-container > view:nth-child(2) { animation-delay: 0.1s; }
.list-container > view:nth-child(3) { animation-delay: 0.15s; }
.list-container > view:nth-child(4) { animation-delay: 0.2s; }
.list-container > view:nth-child(5) { animation-delay: 0.25s; }
.list-container > view:nth-child(6) { animation-delay: 0.3s; }
.list-container > view:nth-child(7) { animation-delay: 0.35s; }
.list-container > view:nth-child(8) { animation-delay: 0.4s; }
.list-container > view:nth-child(9) { animation-delay: 0.45s; }
.list-container > view:nth-child(10) { animation-delay: 0.5s; }

/* ==================== 容器与卡片 ==================== */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: var(--bg-primary);
}

.glass-card {
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

/* 亮色模式下卡片更突出 */
page.theme-light,
.page.theme-light .glass-card {
  background: #FFFFFF;
  border: none;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08), 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
}

.gradient-text {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color), var(--accent-color));
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientMove 3s ease infinite;
}

/* ==================== Vant 组件全局覆盖 ==================== */

/* Cell 单元格 */
.van-cell {
  background: transparent !important;
  color: var(--text-primary) !important;
  padding: 28rpx 24rpx !important;
}

.van-cell::after {
  border-color: var(--border-light) !important;
  left: 24rpx !important;
  right: 24rpx !important;
}

.van-cell__title { color: var(--text-secondary) !important; }
.van-cell__value { color: var(--text-primary) !important; }
.van-cell-group { background: transparent !important; }

/* Field 输入框 */
.van-field {
  background: transparent !important;
  padding: 28rpx 24rpx !important;
}

.van-field__label {
  color: var(--text-secondary) !important;
  font-size: 28rpx !important;
  width: auto !important;
  min-width: 120rpx !important;
}

.van-field__control {
  color: var(--text-primary) !important;
  font-size: 28rpx !important;
}

.van-field__control::placeholder {
  color: var(--text-muted) !important;
}

.van-field__left-icon {
  color: var(--primary-light) !important;
  font-size: 36rpx !important;
}

.van-field__right-icon {
  color: var(--text-muted) !important;
}

/* Button 按钮 */
.van-button--primary {
  background: var(--button-primary-bg) !important;
  border: none !important;
  font-weight: 600 !important;
  color: var(--button-primary-text) !important;
  box-shadow: var(--shadow-button) !important;
}

.van-button--danger {
  background: var(--danger-color) !important;
  border: none !important;
}

.van-button--default {
  background: var(--button-secondary-bg) !important;
  border: 1rpx solid var(--border-color) !important;
  color: var(--button-secondary-text) !important;
}

.van-button--round { border-radius: 48rpx !important; }

/* Tag 标签 */
.van-tag--primary {
  background: rgba(99, 102, 241, 0.15) !important;
  color: var(--primary-color) !important;
  border: none !important;
}

.van-tag--success {
  background: rgba(16, 185, 129, 0.15) !important;
  color: var(--success-color) !important;
  border: none !important;
}

.van-tag--danger {
  background: rgba(239, 68, 68, 0.15) !important;
  color: var(--danger-color) !important;
  border: none !important;
}

/* Search 搜索框 */
.van-search {
  background: transparent !important;
  padding: 16rpx !important;
}

.van-search__content {
  background: var(--bg-input) !important;
  border: none !important;
  border-radius: 32rpx !important;
}

.van-search__content input {
  color: var(--text-primary) !important;
}

.van-search__content input::placeholder {
  color: var(--text-muted) !important;
}

/* Switch 开关 */
.van-switch {
  background: rgba(99, 102, 241, 0.3) !important;
}

.van-switch--on {
  background: var(--primary-color) !important;
}

/* Popup 弹出层 */
.van-popup {
  background: var(--bg-primary) !important;
}

.van-popup--bottom {
  border-top: 1rpx solid var(--border-light) !important;
  border-radius: 24rpx 24rpx 0 0 !important;
}

/* Picker 选择器 */
.van-picker__toolbar { padding: 24rpx !important; }
.van-picker__title {
  color: var(--text-primary) !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
}
.van-picker__cancel { color: var(--text-muted) !important; }
.van-picker__confirm {
  color: var(--primary-color) !important;
  font-weight: 600 !important;
}
.van-picker-column__item { color: var(--text-secondary) !important; }
.van-picker-column__item--selected { color: var(--text-primary) !important; }

/* Dialog 对话框 */
.van-dialog {
  background: var(--bg-secondary) !important;
  border: 1rpx solid var(--border-light) !important;
  border-radius: 24rpx !important;
}

.van-dialog__header { color: var(--text-primary) !important; }
.van-dialog__message { color: var(--text-secondary) !important; }
.van-dialog__confirm { color: var(--primary-color) !important; }
.van-dialog__cancel { color: var(--text-muted) !important; }

/* Notice Bar 通知栏 */
.van-notice-bar {
  border-radius: 16rpx !important;
  margin: 16rpx 0 !important;
}

/* Empty 空状态 */
.van-empty__description { color: var(--text-muted) !important; }

/* Loading 加载 */
.van-loading { color: var(--primary-color) !important; }
.van-loading__text { color: var(--text-secondary) !important; }

/* Icon 图标 */
.van-icon { color: inherit; }

/* Tabbar 底部导航栏 */
.van-tabbar {
  background: var(--tabbar-bg) !important;
  border-top: 1rpx solid var(--border-light) !important;
  box-sizing: border-box !important;
  height: 120rpx !important;
  padding-top: 16rpx !important;
}

.van-tabbar::before,
.van-tabbar::after {
  display: none !important;
}

.van-tabbar-item {
  color: var(--tabbar-color) !important;
  background: transparent !important;
  padding: 12rpx 0 !important;
}

.van-tabbar-item::before,
.van-tabbar-item::after {
  display: none !important;
}

.van-tabbar-item--active {
  color: var(--tabbar-active) !important;
}

.van-tabbar-item__icon {
  font-size: 48rpx !important;
  margin-bottom: 8rpx !important;
}

.van-tabbar-item__text {
  font-size: 24rpx !important;
}

/* 安全区域背景 */
.van-tabbar--safe {
  background: var(--tabbar-bg) !important;
  padding-bottom: constant(safe-area-inset-bottom) !important;
  padding-bottom: env(safe-area-inset-bottom) !important;
}

.tabbar-container {
  background: var(--tabbar-bg) !important;
}

/* ==================== 工具类 ==================== */
.text-center { text-align: center; }
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }

.btn-group { padding: 32rpx 24rpx; }

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 文本溢出处理 ==================== */

/* 单行文本溢出省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 两行文本溢出省略 */
.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 菜单项名称 - 单行省略 */
.menu-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

/* 菜单描述 - 两行省略 */
.menu-desc {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 卡片标题 - 单行省略 */
.card-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 列表项标题 */
.quick-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* 语言值显示 */
.menu-value {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ==================== 亮色模式特殊优化 ==================== */

/* 亮色模式下的输入框 */
page.theme-light,
.page.theme-light .van-field__control {
  background: var(--bg-input);
}

/* 亮色模式下的分割线 */
page.theme-light,
.page.theme-light .van-cell::after {
  border-color: rgba(60, 60, 67, 0.12) !important;
}

/* 亮色模式下的 TabBar */
page.theme-light,
.page.theme-light .van-tabbar {
  border-top: 1rpx solid rgba(60, 60, 67, 0.12) !important;
}

/* 亮色模式下的按钮阴影 */
page.theme-light,
.page.theme-light .van-button--primary {
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.2) !important;
}

/* 亮色模式下的次按钮 */
page.theme-light,
.page.theme-light .van-button--default {
  background: #E5E5EA !important;
  color: #3C3C43 !important;
  border: none !important;
}

/* ==================== Action Sheet 主题适配 ==================== */

/* Action Sheet 层级和主题 */
page {
  --action-sheet-z-index: 9999;
}

.van-action-sheet {
  z-index: 9999 !important;
  background: var(--bg-secondary) !important;
  border-radius: 24rpx 24rpx 0 0 !important;
}

.van-action-sheet__header {
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
  font-weight: 600 !important;
}

.van-action-sheet__description {
  color: var(--text-secondary) !important;
}

.van-action-sheet__content {
  background: var(--bg-secondary) !important;
}

.van-action-sheet__item {
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
  transition: background 0.2s ease !important;
}

.van-action-sheet__item--hover {
  background: var(--card-active-bg) !important;
}

.van-action-sheet__item--disabled {
  color: var(--text-muted) !important;
}

.van-action-sheet__item--loading {
  color: var(--text-muted) !important;
}

.van-action-sheet__cancel {
  background: var(--bg-glass) !important;
  color: var(--text-primary) !important;
  border-top: 16rpx solid var(--bg-primary) !important;
}

.van-action-sheet__cancel::before {
  display: none !important;
}

.van-action-sheet__subname {
  color: var(--text-muted) !important;
  font-size: 24rpx !important;
}

.van-action-sheet__name {
  color: var(--text-primary) !important;
}

.van-action-sheet__gap {
  background: var(--bg-primary) !important;
}

/* 选中状态高亮 */
.van-action-sheet__item.active {
  color: var(--primary-color) !important;
}

.van-action-sheet__item.active .van-action-sheet__name {
  color: var(--primary-color) !important;
  font-weight: 600 !important;
}
