/* 动态详情页 */

.page {
  min-height: 100vh;
  background: #0f0f23;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: #a1a1aa;
}

.detail-content {
  padding: 24rpx;
}

.detail-header {
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(99, 102, 241, 0.15);
  border-radius: 24rpx;
}

.header-tags {
  margin-bottom: 16rpx;
}

.top-tag {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.detail-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #71717a;
}

.meta-author {
  color: #818cf8;
}

.meta-dot {
  margin: 0 8rpx;
}

.meta-time {
  flex: 1;
}

.meta-views {
  color: #a1a1aa;
}

.detail-body {
  padding: 32rpx;
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(99, 102, 241, 0.15);
  border-radius: 24rpx;
  min-height: 300rpx;
}

/* rich-text 组件基础样式 */
.detail-body rich-text {
  color: #e4e4e7;
  font-size: 30rpx;
  line-height: 1.8;
}

.empty-content {
  text-align: center;
  color: #71717a;
  padding: 60rpx 0;
}
