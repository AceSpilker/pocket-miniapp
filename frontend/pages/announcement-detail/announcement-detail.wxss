/* 动态详情页 - 主题适配样式 */

.page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
}

.detail-content {
  padding: 24rpx;
}

.detail-header {
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--border-light);
  border-radius: 24rpx;
}

.header-tags {
  margin-bottom: 16rpx;
}

.top-tag {
  background: linear-gradient(135deg, var(--warning-color), #fbbf24);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.detail-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-muted);
}

.meta-author {
  color: var(--primary-light);
}

.meta-dot {
  margin: 0 8rpx;
}

.meta-time {
  flex: 1;
}

.meta-views {
  color: var(--text-secondary);
}

.detail-body {
  padding: 32rpx;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--border-light);
  border-radius: 24rpx;
  min-height: 300rpx;
}

/* rich-text 组件基础样式 */
.detail-body rich-text {
  color: var(--text-primary);
  font-size: 30rpx;
  line-height: 1.8;
}

.empty-content {
  text-align: center;
  color: var(--text-muted);
  padding: 60rpx 0;
}
