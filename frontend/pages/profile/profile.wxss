/* 个人资料页 - 炫酷科技风 */

.profile-page {
  min-height: 100vh;
  position: relative;
  padding-bottom: 60rpx;
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

.shape-1 {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #6366f1, #ec4899);
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.2;
  top: -100rpx;
  left: -100rpx;
  animation: float 10s ease-in-out infinite;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(99, 102, 241, 0.5);
  box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 4rpx solid #0f0f23;
  box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
}

.avatar-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

/* 表单卡片 */
.form-card {
  margin: 0 24rpx 24rpx;
  padding: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(99, 102, 241, 0.1);
  background: rgba(99, 102, 241, 0.05);
}

/* 输入框 */
.form-card .van-field {
  padding: 28rpx 24rpx !important;
}

/* 按钮组 */
.btn-group {
  padding: 24rpx;
}

.btn-group .van-button--primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4) !important;
  height: 96rpx !important;
}
