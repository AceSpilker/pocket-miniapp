/* 修改密码页 - 主题适配样式 */

.page {
  min-height: 100vh;
  position: relative;
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: var(--bg-primary);
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

.shape-1 {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, var(--secondary-color), #f472b6);
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.2;
  top: -100rpx;
  right: -100rpx;
  animation: float 10s ease-in-out infinite;
}

/* 表单卡片 */
.form-card {
  margin-bottom: 24rpx;
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
  background: var(--bg-glass);
}

/* 输入框 */
.form-card .van-cell {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-cell::after {
  border-bottom: 1rpx solid var(--border-light) !important;
}

.form-card .van-cell:last-child::after {
  display: none !important;
}

/* 按钮组 */
.btn-group {
  padding: 32rpx 0;
}

.btn-group .van-button--primary {
  background: linear-gradient(135deg, var(--secondary-color), #f472b6) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 20px var(--gradient-shape-2) !important;
  height: 96rpx !important;
}

/* 错误提示 */
.page .van-notice-bar {
  margin: 0 0 24rpx !important;
  border-radius: 16rpx !important;
}
