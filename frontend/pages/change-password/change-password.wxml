<view class="page" style="{{cssVars}}">

  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card glass-card fade-in-up">
    <view class="card-title">🔐 修改密码</view>
    <van-cell-group>
      <van-field
        value="{{ oldPassword }}"
        type="password"
        label="原密码"
        placeholder="请输入原密码"
        bind:change="onOldPwdInput"
      />
      <van-field
        value="{{ newPassword }}"
        type="password"
        label="新密码"
        placeholder="至少6位密码"
        bind:change="onNewPwdInput"
      />
      <van-field
        value="{{ confirmPassword }}"
        type="password"
        label="确认密码"
        placeholder="再次输入新密码"
        bind:change="onConfirmPwdInput"
      />
    </van-cell-group>
  </view>

  <!-- 提示消息 -->
  <van-notice-bar
    wx:if="{{errorMsg}}"
    color="#ef4444"
    background="rgba(239, 68, 68, 0.1)"
    text="{{errorMsg}}"
    wrapable
  />

  <!-- 保存按钮 -->
  <view class="btn-group fade-in-up" style="animation-delay: 0.1s;">
    <van-button
      type="primary"
      block
      round
      loading="{{loading}}"
      bind:click="handleChangePassword"
    >
      🔒 确认修改
    </van-button>
  </view>
</view>
