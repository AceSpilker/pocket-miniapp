<view class="page page-enter" style="{{cssVars}}">

  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card glass-card fade-in-up">
    <view class="card-title">🔐 {{i18n.texts['password.title']}}</view>
    <van-cell-group>
      <van-field
        value="{{ oldPassword }}"
        type="password"
        label="{{i18n.texts['password.oldPassword']}}"
        placeholder="{{i18n.texts['password.oldPasswordPlaceholder']}}"
        bind:change="onOldPwdInput"
      />
      <van-field
        value="{{ newPassword }}"
        type="password"
        label="{{i18n.texts['password.newPassword']}}"
        placeholder="{{i18n.texts['password.newPasswordPlaceholder']}}"
        bind:change="onNewPwdInput"
      />
      <van-field
        value="{{ confirmPassword }}"
        type="password"
        label="{{i18n.texts['password.confirmPassword']}}"
        placeholder="{{i18n.texts['password.confirmPasswordPlaceholder']}}"
        bind:change="onConfirmPwdInput"
      />
    </van-cell-group>
  </view>

  <!-- 提示消息 -->
  <van-notice-bar
    wx:if="{{errorMsg}}"
    color="#ef4444"
    background="rgba(239, 68, 68, 0.1)"
    text="{{errorMsg}}"
    wrapable
  />

  <!-- 保存按钮 -->
  <view class="btn-group fade-in-up" style="animation-delay: 0.1s;">
    <van-button
      type="primary"
      block
      round
      loading="{{loading}}"
      bind:click="handleChangePassword"
    >
      🔒 {{i18n.texts['password.button']}}
    </van-button>
  </view>
</view>
