/* 注册页 - 主题适配样式 */

.register-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-primary);
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
}

.shape-1 {
  width: 350rpx;
  height: 350rpx;
  background: linear-gradient(135deg, var(--primary-light), #a78bfa);
  top: 100rpx;
  right: -80rpx;
  animation: float 8s ease-in-out infinite;
}

.shape-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, var(--accent-color), #22d3ee);
  bottom: 300rpx;
  left: -100rpx;
  animation: float 6s ease-in-out infinite reverse;
}

/* 标题 */
.header {
  padding: 60rpx 24rpx 40rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  margin: 0 24rpx;
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

/* 输入框 */
.form-card .van-field {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-field::after {
  border-bottom: 1rpx solid var(--border-light) !important;
}

.form-card .van-field:last-child::after {
  border-bottom: none !important;
}

.form-card .van-field__label {
  color: var(--text-secondary) !important;
  font-size: 28rpx !important;
  width: auto !important;
  min-width: 140rpx !important;
}

.form-card .van-field__control {
  color: var(--text-primary) !important;
  font-size: 28rpx !important;
}

.form-card .van-field__control::placeholder {
  color: var(--text-muted) !important;
}

/* 错误提示 */
.error-notice {
  margin: 20rpx 24rpx !important;
  border-radius: 16rpx !important;
  background: rgba(239, 68, 68, 0.1) !important;
  border: 1rpx solid rgba(239, 68, 68, 0.2) !important;
}

/* 按钮组 */
.btn-group {
  padding: 32rpx 24rpx;
}

/* 注册按钮 */
.register-btn {
  background: linear-gradient(135deg, var(--secondary-color), #f472b6) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx !important;
  box-shadow: 0 4px 20px var(--gradient-shape-2) !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
}

.register-btn:active {
  opacity: 0.9 !important;
  transform: scale(0.98) !important;
}

/* 登录链接 */
.login-link {
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.link {
  color: var(--secondary-color);
  font-weight: 500;
}

/* 协议 */
.agreement {
  text-align: center;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  font-size: 24rpx;
  color: var(--text-muted);
}

.agreement .link {
  color: var(--primary-light);
}
