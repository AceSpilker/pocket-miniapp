<view class="register-page page-enter" style="{{cssVars}}">

  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
    <view class="shape shape-2"></view>
  </view>

  <!-- 标题 -->
  <view class="header fade-in-up">
    <text class="title gradient-text">✨ {{i18n.texts['register.title']}}</text>
    <text class="subtitle">{{i18n.texts['register.subtitle']}}</text>
  </view>

  <!-- 表单 -->
  <view class="form-card fade-in-up glass-card" style="animation-delay: 0.1s;">
    <van-cell-group>
      <van-field
        value="{{ username }}"
        label="{{i18n.texts['register.username']}}"
        required
        placeholder="{{i18n.texts['register.usernamePlaceholder']}}"
        bind:change="onUsernameInput"
        custom-class="input-field"
      />
      <van-field
        value="{{ nickname }}"
        label="{{i18n.texts['register.nickname']}}"
        placeholder="{{i18n.texts['register.nicknamePlaceholder']}}"
        bind:change="onNicknameInput"
        custom-class="input-field"
      />
      <van-field
        value="{{ password }}"
        type="password"
        label="{{i18n.texts['register.password']}}"
        required
        placeholder="{{i18n.texts['register.passwordPlaceholder']}}"
        bind:change="onPasswordInput"
        custom-class="input-field"
      />
      <van-field
        value="{{ confirmPassword }}"
        type="password"
        label="{{i18n.texts['register.confirmPassword']}}"
        required
        placeholder="{{i18n.texts['register.confirmPasswordPlaceholder']}}"
        bind:change="onConfirmPasswordInput"
        custom-class="input-field"
      />
    </van-cell-group>
  </view>

  <!-- 错误提示 -->
  <van-notice-bar
    wx:if="{{errorMsg}}"
    color="#ef4444"
    background="rgba(239, 68, 68, 0.1)"
    text="{{errorMsg}}"
    wrapable
    custom-class="error-notice"
  />

  <!-- 注册按钮 -->
  <view class="btn-group fade-in-up" style="animation-delay: 0.2s;">
    <van-button
      type="primary"
      block
      round
      loading="{{loading}}"
      bind:click="handleRegister"
      custom-class="register-btn"
    >
      🚀 {{i18n.texts['register.button']}}
    </van-button>
  </view>

  <!-- 登录链接 -->
  <view class="login-link fade-in" style="animation-delay: 0.3s;">
    <text>{{i18n.texts['register.hasAccount']}}</text>
    <text class="link tap-opacity" bindtap="goLogin">{{i18n.texts['register.goLogin']}} 🔥</text>
  </view>

  <!-- 协议 -->
  <view class="agreement fade-in" style="animation-delay: 0.35s;">
    <text>{{i18n.texts['register.agreement']}}</text>
    <text class="link tap-opacity" bindtap="goUserAgreement">《{{i18n.texts['login.userAgreement']}}》</text>
    <text>{{i18n.texts['login.and']}}</text>
    <text class="link tap-opacity" bindtap="goPrivacyPolicy">《{{i18n.texts['login.privacyPolicy']}}》</text>
  </view>
</view>
