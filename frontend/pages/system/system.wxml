<view class="page page-enter" style="{{cssVars}}" wx:if="{{hasAccess}}">

  <!-- 动态渐变背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
    <view class="shape shape-2"></view>
  </view>

  <!-- 固定标题区 -->
  <view class="header-fixed fade-in-down">
    <view class="header-content">
      <text class="title">⚙️ {{i18n.texts['system.title']}}</text>
      <text class="subtitle">{{i18n.texts['system.subtitle']}}</text>
    </view>
  </view>

  <!-- 可滚动菜单区域 -->
  <scroll-view class="menu-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="menu-list">
      <view class="menu-item list-item-anim glass-card tap-scale" bindtap="goTo" data-url="/pages/admin/users/users" style="animation-delay: 0.05s;">
        <view class="menu-icon icon-bg-primary">
          <text>👥</text>
        </view>
        <view class="menu-content">
          <text class="menu-name">{{i18n.texts['system.users']}}</text>
          <text class="menu-desc">{{i18n.texts['system.usersDesc']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>

      <view class="menu-item list-item-anim glass-card tap-scale" bindtap="goTo" data-url="/pages/admin/roles/roles" style="animation-delay: 0.1s;">
        <view class="menu-icon icon-bg-secondary">
          <text>🔑</text>
        </view>
        <view class="menu-content">
          <text class="menu-name">{{i18n.texts['system.roles']}}</text>
          <text class="menu-desc">{{i18n.texts['system.rolesDesc']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>

      <view class="menu-item list-item-anim glass-card tap-scale" bindtap="goTo" data-url="/pages/admin/menus/menus" style="animation-delay: 0.15s;">
        <view class="menu-icon icon-bg-accent">
          <text>📋</text>
        </view>
        <view class="menu-content">
          <text class="menu-name">{{i18n.texts['system.menus']}}</text>
          <text class="menu-desc">{{i18n.texts['system.menusDesc']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>

      <view class="menu-item list-item-anim glass-card tap-scale" bindtap="goTo" data-url="/pages/admin/announcements/announcements" style="animation-delay: 0.2s;">
        <view class="menu-icon icon-bg-warning">
          <text>📢</text>
        </view>
        <view class="menu-content">
          <text class="menu-name">{{i18n.texts['system.announcements']}}</text>
          <text class="menu-desc">{{i18n.texts['system.announcementsDesc']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>

      <view class="menu-item list-item-anim glass-card tap-scale" bindtap="goTo" data-url="/pages/admin/feedbacks/feedbacks" style="animation-delay: 0.25s;">
        <view class="menu-icon icon-bg-success">
          <text>💬</text>
        </view>
        <view class="menu-content">
          <text class="menu-name">{{i18n.texts['system.feedbacks']}}</text>
          <text class="menu-desc">{{i18n.texts['system.feedbacksDesc']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>

      <view class="menu-item list-item-anim glass-card tap-scale" bindtap="goTo" data-url="/pages/admin/features/features" style="animation-delay: 0.3s;">
        <view class="menu-icon icon-bg-primary">
          <text>🎮</text>
        </view>
        <view class="menu-content">
          <text class="menu-name">{{i18n.texts['system.features']}}</text>
          <text class="menu-desc">{{i18n.texts['system.featuresDesc']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>
    </view>
  </scroll-view>
</view>

<view class="no-access fade-in" style="{{cssVars}}" wx:else>
  <text>🚫 {{i18n.texts['system.noAccess']}}</text>
</view>
