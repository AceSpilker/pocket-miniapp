/* 系统管理页 - 主题适配样式 */

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
  position: relative;
}

.no-access {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-muted);
  background: var(--bg-primary);
}

/* 动态渐变背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.25;
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  top: -100rpx;
  right: -100rpx;
  animation: float 10s ease-in-out infinite;
}

.shape-2 {
  width: 350rpx;
  height: 350rpx;
  background: linear-gradient(135deg, var(--secondary-color), #f472b6);
  bottom: 200rpx;
  left: -100rpx;
  animation: float 12s ease-in-out infinite reverse;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

/* 固定标题区 */
.header-fixed {
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--bg-primary);
}

.header-content {
  padding: 40rpx 24rpx 24rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

/* 可滚动菜单区域 */
.menu-scroll {
  flex: 1;
  height: calc(100vh - 160rpx);
  position: relative;
  z-index: 1;
}

.menu-list {
  padding: 16rpx 24rpx 40rpx;
}

/* 菜单项 - 一行一行显示 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-light);
  transition: all 0.2s ease;
}

.menu-item:active {
  background: var(--card-active-bg);
  transform: scale(0.99);
}

/* 图标 */
.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  box-shadow: 0 4px 12px var(--shadow-color);
  flex-shrink: 0;
}

/* 图标背景色 - 使用 CSS 变量实现主题切换 */
.icon-bg-primary { background: var(--icon-bg-primary); }
.icon-bg-secondary { background: var(--icon-bg-secondary); }
.icon-bg-success { background: var(--icon-bg-success); }
.icon-bg-warning { background: var(--icon-bg-warning); }
.icon-bg-accent { background: var(--icon-bg-accent); }
.icon-bg-danger { background: var(--icon-bg-danger); }

/* 内容区 */
.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}
