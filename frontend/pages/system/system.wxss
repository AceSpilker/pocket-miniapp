/* 系统管理页 - 炫酷科技风 */

.page {
  min-height: 100vh;
  position: relative;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.no-access {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #71717a;
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.25;
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  top: -100rpx;
  right: -100rpx;
  animation: float 10s ease-in-out infinite;
}

.shape-2 {
  width: 350rpx;
  height: 350rpx;
  background: linear-gradient(135deg, #ec4899, #f472b6);
  bottom: 200rpx;
  left: -100rpx;
  animation: float 12s ease-in-out infinite reverse;
}

/* 标题区 */
.header {
  padding: 30rpx 0;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #a1a1aa;
  letter-spacing: 2rpx;
}

/* 功能网格 */
.grid-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 24rpx;
}

.grid-item {
  width: calc(50% - 10rpx);
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.15);
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

.grid-item:active {
  transform: scale(0.96);
  background: rgba(30, 30, 60, 0.8);
}

.grid-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
}

.grid-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.grid-desc {
  font-size: 22rpx;
  color: #71717a;
  text-align: center;
}
