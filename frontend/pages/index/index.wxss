/* 首页 - 主题适配样式 */

page {
  padding-bottom: 0;
}

.container {
  min-height: 100vh;
  position: relative;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background: var(--bg-primary);
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.3;
}

.shape-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  top: -200rpx;
  left: -100rpx;
  animation: float 15s ease-in-out infinite;
}

.shape-2 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, var(--secondary-color), #f472b6);
  bottom: 200rpx;
  right: -150rpx;
  animation: float 12s ease-in-out infinite reverse;
}

/* 欢迎卡片 */
.welcome-card {
  margin: 24rpx;
}

.welcome-content {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.avatar-wrap {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  margin-right: 24rpx;
}

.avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border-color);
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-light);
  animation: pulse 2s ease-in-out infinite;
}

.welcome-info { flex: 1; }

.welcome-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.welcome-desc { font-size: 24rpx; color: var(--text-secondary); }

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.title-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, var(--border-color), transparent);
}

.title-more {
  font-size: 24rpx;
  color: var(--primary-light);
  margin-left: 16rpx;
}

/* 功能网格 */
.feature-grid {
  display: grid;
  gap: 20rpx;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}

/* 1个功能：单列居中 */
.feature-grid-1 {
  grid-template-columns: 1fr;
  max-width: 400rpx;
  margin: 0 auto;
}

/* 2个功能：两列平分 */
.feature-grid-2 {
  grid-template-columns: repeat(2, 1fr);
}

/* 3个功能：三列平分 */
.feature-grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

/* 4个及以上功能：两列 */
.feature-grid-4,
.feature-grid-5,
.feature-grid-6 {
  grid-template-columns: repeat(2, 1fr);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  border: 1rpx solid var(--border-light);
  transition: all 0.3s ease;
  animation: fadeInUp 0.5s ease-out forwards;
  opacity: 0;
  box-shadow: var(--shadow-card);
  position: relative;
  min-height: 240rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.feature-item:active {
  transform: scale(0.96);
  background: var(--bg-secondary);
}

.feature-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  box-shadow: 0 4px 15px var(--shadow-color);
  flex-shrink: 0;
}

/* 图标背景色 - 使用 CSS 变量实现主题切换 */
.icon-bg-primary { background: var(--icon-bg-primary); }
.icon-bg-secondary { background: var(--icon-bg-secondary); }
.icon-bg-success { background: var(--icon-bg-success); }
.icon-bg-warning { background: var(--icon-bg-warning); }
.icon-bg-accent { background: var(--icon-bg-accent); }
.icon-bg-danger { background: var(--icon-bg-danger); }

.feature-icon { font-size: 44rpx; }

.feature-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
  text-align: center;
}

.feature-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  width: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
  text-align: center;
  line-height: 1.4;
}

/* 功能项禁用状态 */
.feature-item.disabled {
  opacity: 0.6;
}

/* 开发中标签 */
.dev-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  background: rgba(245, 158, 11, 0.15);
  color: var(--warning-color);
  border-radius: 12rpx;
}

/* 功能空状态 */
.feature-empty {
  margin: 0 24rpx;
  position: relative;
  z-index: 1;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 快捷列表 */
.quick-list {
  margin: 0 24rpx;
  padding: 0;
}

.quick-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.quick-item:last-child { border-bottom: none; }

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  box-shadow: 0 4px 15px var(--shadow-color);
}

.quick-content { flex: 1; }

.quick-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

/* 动态标题单行显示，超出显示... */
.announcement-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.quick-sub { font-size: 22rpx; color: var(--text-muted); }

.quick-item .van-icon { color: var(--text-muted) !important; }

/* 查看更多入口 */
.more-item {
  justify-content: center;
  background: var(--bg-glass) !important;
}

.more-item:active {
  background: var(--bg-secondary) !important;
}

.more-text {
  font-size: 26rpx;
  color: var(--primary-light);
  font-weight: 500;
}

.more-item .van-icon {
  color: var(--primary-light) !important;
  margin-left: 8rpx;
}
