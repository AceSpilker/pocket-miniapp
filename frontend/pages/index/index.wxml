<view class="container page-enter" style="{{cssVars}}">

  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
    <view class="shape shape-2"></view>
  </view>

  <!-- 用户欢迎卡片 -->
  <view class="welcome-card glass-card fade-in-up">
    <view class="welcome-content tap-scale" bindtap="goLogin">
      <view class="avatar-wrap glow-animation">
        <image
          class="avatar-img"
          src="{{hasLogin && userInfo.avatar_url ? userInfo.avatar_url : '/assets/images/default-avatar.png'}}"
        />
        <view class="avatar-ring"></view>
      </view>
      <view class="welcome-info">
        <text class="welcome-name">{{hasLogin ? (userInfo.nickname || i18n.texts['index.defaultUser']) : '👋 ' + i18n.texts['index.welcome']}}</text>
        <text class="welcome-desc">{{hasLogin ? i18n.texts['index.exploreMore'] + ' ✨' : i18n.texts['index.loginHint']}}</text>
      </view>
      <van-icon wx:if="{{!hasLogin}}" name="arrow" size="40rpx" custom-style="color: var(--primary-light);" />
    </view>
  </view>

  <!-- 功能网格 -->
  <view class="section-title fade-in-up" style="animation-delay: 0.1s;">
    <text class="title-text">🎮 {{i18n.texts['index.featureCenter']}}</text>
    <text class="title-line"></text>
    <text class="title-more tap-opacity" bindtap="goFeatures" wx:if="{{hasLogin && features.length > 0}}">{{i18n.texts['index.more']}} ></text>
  </view>

  <view class="feature-grid feature-grid-{{features.length}} fade-in-up" style="animation-delay: 0.15s;" wx:if="{{features.length > 0}}">
    <view
      class="feature-item tap-scale {{!item.is_enabled ? 'disabled' : ''}}"
      wx:for="{{features}}"
      wx:key="id"
      data-feature="{{item}}"
      bindtap="onFeatureTap"
      style="animation-delay: {{0.2 + index * 0.05}}s;"
    >
      <view class="feature-icon-wrap" style="background: {{item.icon_bg_color || 'var(--icon-bg-primary)'}};">
        <text class="feature-icon">{{item.icon || '📦'}}</text>
      </view>
      <text class="feature-name">{{item.name}}</text>
      <text class="feature-desc">{{item.description || ''}}</text>
      <view class="dev-tag" wx:if="{{!item.is_enabled}}">{{i18n.texts['index.developing']}}</view>
    </view>
  </view>

  <!-- 空状态提示 -->
  <view class="feature-empty fade-in-up" style="animation-delay: 0.15s;" wx:if="{{features.length === 0}}">
    <view class="empty-card glass-card tap-scale" bindtap="goLogin" wx:if="{{!hasLogin}}">
      <text class="empty-icon">🔐</text>
      <text class="empty-title">{{i18n.texts['index.loginToUnlock']}}</text>
      <text class="empty-desc">{{i18n.texts['index.loginToUnlockDesc']}}</text>
    </view>
    <view class="empty-card glass-card" wx:else>
      <text class="empty-icon">📦</text>
      <text class="empty-title">{{i18n.texts['index.noFeatures']}}</text>
      <text class="empty-desc">{{i18n.texts['index.noFeaturesDesc']}}</text>
    </view>
  </view>

  <!-- 最近动态 -->
  <view class="section-title fade-in-up" style="animation-delay: 0.3s;">
    <text class="title-text">🔥 {{i18n.texts['index.recentNews']}}</text>
    <text class="title-line"></text>
    <text class="title-more tap-opacity" bindtap="goAnnouncements">{{i18n.texts['index.more']}} ></text>
  </view>

  <view class="quick-list glass-card fade-in-up" style="animation-delay: 0.35s;">
    <!-- 有数据时显示列表 -->
    <block wx:if="{{latestAnnouncements.length > 0}}">
      <view
        class="quick-item announcement-item tap-bg"
        wx:for="{{latestAnnouncements}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goAnnouncementDetail"
      >
        <view class="quick-icon icon-bg-warning">
          <text>{{item.is_top ? '📌' : '📰'}}</text>
        </view>
        <view class="quick-content">
          <text class="quick-title announcement-title">{{item.title}}</text>
          <text class="quick-sub">{{item.author_name || i18n.texts['index.admin']}} · {{item.created_at}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>
    </block>
    <!-- 无数据时显示提示 -->
    <block wx:else>
      <view class="quick-item tap-bg" bindtap="goAnnouncements">
        <view class="quick-icon icon-bg-warning">
          <text>🔥</text>
        </view>
        <view class="quick-content">
          <text class="quick-title">{{i18n.texts['index.noNews']}}</text>
          <text class="quick-sub">{{i18n.texts['index.clickToViewAll']}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>
    </block>
  </view>

  <!-- 小提示 -->
  <view class="section-title fade-in-up" style="animation-delay: 0.4s;">
    <text class="title-text">💡 {{i18n.texts['index.tips']}}</text>
    <text class="title-line"></text>
  </view>

  <view class="quick-list glass-card fade-in-up" style="animation-delay: 0.45s;">
    <view class="quick-item tap-bg">
      <view class="quick-icon icon-bg-success">
        <text>💡</text>
      </view>
      <view class="quick-content">
        <text class="quick-title">{{i18n.texts['index.completeProfile']}}</text>
        <text class="quick-sub">{{i18n.texts['index.completeProfileDesc']}}</text>
      </view>
      <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
    </view>
  </view>
</view>
