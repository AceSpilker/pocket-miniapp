<view class="page page-enter" style="{{cssVars}}">

  <!-- 顶部提示组件 -->
  <top-toast id="top-toast" />

  <!-- 列表 -->
  <van-loading wx:if="{{loading}}" size="48rpx" custom-class="loading-wrap">{{i18n.texts['common.loading']}}</van-loading>
  <van-empty wx:elif="{{list.length === 0}}" description="{{i18n.texts['announcement.noData']}}" />

  <view wx:else class="announcement-list">
    <view
      class="announcement-item glass-card list-item-anim tap-scale"
      wx:for="{{list}}"
      wx:key="id"
      style="animation-delay: {{index * 0.05}}s;"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="item-content">
        <view class="item-title">
          <text class="top-tag" wx:if="{{item.is_top}}">{{i18n.texts['announcement.pinned']}}</text>
          <text class="title-text">{{item.title}}</text>
        </view>
        <view class="item-meta">
          <text class="meta-author" wx:if="{{item.author_name}}">{{item.author_name}}</text>
          <text class="meta-dot" wx:if="{{item.author_name}}">·</text>
          <text class="meta-time">{{item.created_at}}</text>
          <text class="meta-views">👁 {{item.view_count}}</text>
        </view>
      </view>
      <view class="item-arrow">
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>
    </view>
  </view>
</view>
