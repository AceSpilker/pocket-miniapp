/* 动态列表页 - 主题适配样式 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background: var(--bg-primary);
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
}

.announcement-list {
  padding: 0;
}

.announcement-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--border-light);
  border-radius: 24rpx;
}

.announcement-item:active {
  background: var(--bg-secondary);
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.top-tag {
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--warning-color), #fbbf24);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-muted);
}

.meta-author {
  color: var(--primary-light);
}

.meta-dot {
  margin: 0 8rpx;
}

.meta-time {
  flex: 1;
}

.meta-views {
  margin-left: 16rpx;
}

.item-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}
