<view class="container page-enter" style="{{cssVars}}">
  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="profile-card glass-card fade-in-up tap-scale" bindtap="{{hasLogin ? '' : 'goLogin'}}">
    <!-- 未登录状态 -->
    <view class="profile-content" wx:if="{{!hasLogin}}">
      <view class="avatar-wrap">
        <image class="avatar-img" src="/assets/images/default-avatar.png" />
      </view>
      <view class="profile-info">
        <text class="profile-name">👋 {{i18n.texts['mine.notLoggedIn']}}</text>
        <text class="profile-desc">{{i18n.texts['mine.clickToLogin']}}</text>
      </view>
    </view>

    <!-- 已登录状态 -->
    <block wx:if="{{hasLogin}}">
      <view class="profile-header">
        <view class="avatar-wrap">
          <image class="avatar-img" src="{{userInfo.avatar_url || '/assets/images/default-avatar.png'}}" />
          <view class="avatar-badge">✨</view>
        </view>
        <view class="profile-basic">
          <text class="profile-name">{{userInfo.nickname || i18n.texts['mine.defaultUser']}}</text>
          <text class="profile-username">@{{userInfo.username || '--'}}</text>
        </view>
      </view>

      <!-- 联系信息 -->
      <view class="profile-contact">
        <view class="contact-item" wx:if="{{userInfo.phone}}">
          <view class="contact-icon">
            <text>📱</text>
          </view>
          <view class="contact-content">
            <text class="contact-label">{{i18n.texts['mine.phone']}}</text>
            <text class="contact-value">{{maskedPhone}}</text>
          </view>
        </view>
        <view class="contact-item" wx:if="{{userInfo.email}}">
          <view class="contact-icon">
            <text>📧</text>
          </view>
          <view class="contact-content">
            <text class="contact-label">{{i18n.texts['mine.email']}}</text>
            <text class="contact-value">{{maskedEmail}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 系统管理入口（仅管理员可见） -->
  <view class="system-section fade-in-up" style="animation-delay: 0.05s;" wx:if="{{isAdmin}}">
    <view class="system-card glass-card tap-scale" bindtap="onMenuTap" data-url="/pages/system/system">
      <view class="system-icon icon-bg-primary">
        <text>⚙️</text>
      </view>
      <view class="system-info">
        <text class="system-name">{{i18n.texts['mine.systemManage']}}</text>
        <text class="system-desc">{{i18n.texts['mine.systemManageDesc']}}</text>
      </view>
      <van-icon name="arrow" size="40rpx" custom-style="color: var(--text-muted);" />
    </view>
  </view>

  <!-- 菜单分组 -->
  <view wx:for="{{menuGroups}}" wx:key="title" class="menu-group fade-in-up" style="animation-delay: {{0.1 + index * 0.05}}s;">
    <view class="group-title">
      <text class="title-text">{{item.title}}</text>
      <text class="title-line"></text>
    </view>
    <view class="menu-card glass-card">
      <view
        class="menu-item tap-bg"
        wx:for="{{item.items}}"
        wx:key="name"
        wx:for-item="menuItem"
        data-url="{{menuItem.url}}"
        data-action="{{menuItem.action}}"
        bindtap="onMenuTap"
      >
        <view class="menu-icon icon-bg-{{menuItem.iconType}}">
          <text>{{menuItem.icon}}</text>
        </view>
        <text class="menu-name">{{menuItem.name}}</text>
        <text class="menu-value" wx:if="{{menuItem.action === 'language'}}">{{currentLanguage === 'zh-CN' ? '中文' : currentLanguage === 'en-US' ? 'English' : '日本語'}}</text>
        <van-icon name="arrow" size="32rpx" custom-style="color: var(--text-muted);" />
      </view>
    </view>
  </view>

  <!-- 主题切换卡片 -->
  <view class="theme-section fade-in-up" style="animation-delay: 0.25s;">
    <theme-toggle />
  </view>

  <!-- 退出登录 -->
  <view class="logout-section fade-in-up" style="animation-delay: 0.3s;" wx:if="{{hasLogin}}">
    <van-button custom-class="logout-btn" block round bind:click="handleLogout">
      🚪 {{i18n.texts['mine.logout']}}
    </van-button>
  </view>

  <!-- 语言选择器 -->
  <van-action-sheet
    show="{{showLanguageSelector}}"
    actions="{{languageActions}}"
    cancel-text="{{i18n.texts['common.cancel']}}"
    bind:select="onSelectLanguage"
    bind:cancel="onCloseLanguagePicker"
    bind:close="onCloseLanguagePicker"
  />
</view>
