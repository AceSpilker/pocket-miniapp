/* 我的页面 - 主题适配样式 */

page {
  padding-bottom: 0;
}

.container {
  min-height: 100vh;
  position: relative;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background: var(--bg-primary);
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

.shape-1 {
  position: absolute;
  width: 450rpx;
  height: 450rpx;
  background: linear-gradient(135deg, var(--primary-light), #a78bfa);
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.25;
  top: -150rpx;
  right: -100rpx;
  animation: float 12s ease-in-out infinite;
}

/* 用户信息卡片 */
.profile-card {
  margin: 24rpx;
  padding: 32rpx !important;
}

/* 未登录状态 */
.profile-content {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border-color);
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: 3rpx solid var(--bg-primary);
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.profile-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 已登录状态 - 头部区域 */
.profile-header {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
  margin-bottom: 24rpx;
}

.profile-header .avatar-wrap {
  margin-right: 24rpx;
}

.profile-basic {
  flex: 1;
}

.profile-basic .profile-name {
  margin-bottom: 4rpx;
}

.profile-username {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 联系信息区域 */
.profile-contact {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-glass);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-light);
}

.contact-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: var(--card-active-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.contact-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.contact-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 系统管理入口 */
.system-section {
  margin: 0 24rpx 16rpx;
}

.system-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx !important;
  background: linear-gradient(135deg, var(--gradient-shape-1), var(--gradient-shape-2)) !important;
  border: 1rpx solid var(--border-color) !important;
}

.system-card:active {
  background: linear-gradient(135deg, var(--bg-secondary), var(--bg-glass)) !important;
}

.system-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  box-shadow: 0 4px 15px var(--shadow-color);
}

/* 图标背景色 - 使用 CSS 变量实现主题切换 */
.icon-bg-primary { background: var(--icon-bg-primary); }
.icon-bg-secondary { background: var(--icon-bg-secondary); }
.icon-bg-success { background: var(--icon-bg-success); }
.icon-bg-warning { background: var(--icon-bg-warning); }
.icon-bg-accent { background: var(--icon-bg-accent); }
.icon-bg-danger { background: var(--icon-bg-danger); }

.system-info {
  flex: 1;
}

.system-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.system-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 菜单分组 */
.menu-group {
  margin-bottom: 16rpx;
}

.group-title {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.title-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, var(--border-light), transparent);
}

/* 菜单卡片 */
.menu-card {
  margin: 0 24rpx;
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-glass);
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  box-shadow: 0 4px 15px var(--shadow-color);
}

.menu-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

/* 语言值显示 */
.menu-value {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 主题切换区域 */
.theme-section {
  margin: 0 24rpx 16rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 24rpx;
  margin-top: 24rpx;
}

/* 退出按钮样式 */
.logout-btn {
  background: transparent !important;
  border: 2rpx solid rgba(239, 68, 68, 0.3) !important;
  border-radius: 48rpx !important;
  font-size: 28rpx !important;
  color: var(--danger-color) !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
}

.logout-btn:active {
  background: rgba(239, 68, 68, 0.1) !important;
}

/* 语言选择器样式修复 */
page {
  --action-sheet-z-index: 9999;
}

/* 语言选择器层级和主题适配 */
.van-action-sheet {
  z-index: 9999 !important;
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__header {
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__content {
  background: var(--bg-secondary) !important;
}

.van-action-sheet__item {
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__item--hover {
  background: var(--card-active-bg) !important;
}

.van-action-sheet__item--disabled {
  color: var(--text-muted) !important;
}

.van-action-sheet__cancel {
  background: var(--bg-glass) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__subname {
  color: var(--text-muted) !important;
}

/* 当前语言选项高亮 */
.active-lang {
  color: var(--primary-color) !important;
  font-weight: 600;
}

.active-lang .van-action-sheet__name {
  color: var(--primary-color) !important;
}
