/* 意见反馈编辑页 */

.page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 120rpx;
  position: relative;
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.shape-1 {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.2;
  top: -100rpx;
  right: -100rpx;
}

/* 标题区 */
.header {
  padding: 40rpx 24rpx 24rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 版本历史区域 */
.versions-section {
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.section-header.clickable {
  cursor: pointer;
}

.section-header.clickable:active {
  background: var(--card-active-bg);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.toggle-icon {
  font-size: 24rpx;
  color: var(--primary-color);
}

.versions-list {
  border-top: 1rpx solid var(--border-light);
}

.version-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.version-item:last-child {
  border-bottom: none;
}

.version-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.version-num {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.version-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.version-title {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.version-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 版本内嵌回复 */
.version-reply {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(99, 102, 241, 0.08);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--primary-color);
}

.version-reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.version-reply-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.version-reply-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.version-reply-content {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.version-reply-author {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  margin: 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.required {
  color: var(--danger-color);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  line-height: 1.6;
}

.form-textarea::placeholder {
  color: var(--text-muted);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 错误提示 */
.error-msg {
  margin: 0 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 12rpx;
  position: relative;
  z-index: 1;
}

.error-msg text {
  font-size: 26rpx;
  color: var(--danger-color);
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}
