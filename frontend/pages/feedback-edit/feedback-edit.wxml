<view class="page page-enter" style="{{cssVars}}">
  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
  </view>

  <!-- 标题区 -->
  <view class="header fade-in-down">
    <view class="header-row">
      <text class="title">💬 {{i18n.texts['feedback.title']}}</text>
    </view>
    <text class="subtitle">{{i18n.texts['feedback.subtitle']}}</text>
  </view>

  <!-- 版本历史（编辑时显示，包含每个版本的回复） -->
  <view class="versions-section fade-in" wx:if="{{isEdit && versions.length > 0}}">
    <view class="section-header clickable tap-scale" bindtap="toggleVersions">
      <text class="section-title">📜 {{i18n.texts['feedback.versionHistory']}} ({{versions.length}})</text>
      <text class="toggle-icon">{{showVersions ? i18n.texts['feedback.collapse'] : i18n.texts['feedback.expand']}}</text>
    </view>
    <view class="versions-list" wx:if="{{showVersions}}">
      <view class="version-item list-item-anim" wx:for="{{versions}}" wx:key="id" style="animation-delay: {{index * 0.05}}s;">
        <view class="version-header">
          <text class="version-num">{{i18n.texts['feedback.version']}} {{item.version}}</text>
          <text class="version-time">{{item.created_at}}</text>
        </view>
        <text class="version-title">{{item.title}}</text>
        <text class="version-content" wx:if="{{item.content}}">{{item.content}}</text>
        <!-- 该版本的管理员回复 -->
        <view class="version-reply" wx:if="{{item.reply}}">
          <view class="version-reply-header">
            <text class="version-reply-label">📢 {{i18n.texts['feedback.adminReply']}}</text>
            <text class="version-reply-time">{{item.replied_at}}</text>
          </view>
          <text class="version-reply-content">{{item.reply}}</text>
          <text class="version-reply-author">{{i18n.texts['feedback.replier']}}: {{item.replier_name || i18n.texts['feedback.admin']}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-card glass-card fade-in-up" style="animation-delay: 0.1s;">
    <view class="form-item">
      <text class="form-label">{{i18n.texts['feedback.titleLabel']}} <text class="required">*</text></text>
      <input
        class="form-input"
        placeholder="{{i18n.texts['feedback.titlePlaceholder']}}"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="200"
      />
    </view>

    <view class="form-item">
      <text class="form-label">{{i18n.texts['feedback.contentLabel']}}</text>
      <textarea
        class="form-textarea"
        placeholder="{{i18n.texts['feedback.contentPlaceholder']}}"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="5000"
        auto-height
      />
      <text class="char-count">{{content.length || 0}}/5000</text>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error-msg fade-in" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section fade-in-up" style="animation-delay: 0.15s;">
    <button class="submit-btn tap-scale" bindtap="handleSubmit" loading="{{saving}}">
      {{isEdit ? i18n.texts['feedback.saveEdit'] : i18n.texts['feedback.submit']}}
    </button>
  </view>
</view>
