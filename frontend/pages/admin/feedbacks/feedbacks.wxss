/* 管理员意见反馈列表页 */

.page {
  min-height: 100vh;
  background: var(--bg-primary);
  position: relative;
}

.no-access {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-muted);
  background: var(--bg-primary);
}

/* Tab 筛选 */
.tabs {
  display: flex;
  background: var(--bg-card);
  padding: 16rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--border-light);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-input);
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.tab.active {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #ffffff;
}

/* 反馈列表 */
.feedback-list {
  padding: 16rpx 24rpx;
}

.feedback-item {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-light);
}

.feedback-item:active {
  background: var(--card-active-bg);
}

.feedback-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.feedback-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.feedback-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: rgba(245, 158, 11, 0.15);
  color: var(--warning-color);
}

.status-replied {
  background: rgba(99, 102, 241, 0.15);
  color: var(--primary-color);
}

.status-resolved {
  background: rgba(16, 185, 129, 0.15);
  color: var(--success-color);
}

.feedback-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.feedback-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.version-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  background: var(--card-active-bg);
  color: var(--text-muted);
  border-radius: 8rpx;
}

.meta-text {
  font-size: 22rpx;
  color: var(--primary-color);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}
