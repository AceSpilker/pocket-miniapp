/* 动态编辑页 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background: var(--bg-primary);
}

.form-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 24rpx 0 16rpx;
}

.form-card {
  margin-bottom: 24rpx;
  padding: 0;
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
}

/* 富文本编辑器 */
.editor-card {
  padding: 0;
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  overflow: hidden;
}

.editor-toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--border-light);
  border-bottom: 1rpx solid var(--border-color);
  flex-wrap: wrap;
  gap: 8rpx;
}

.tool-item {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border-color);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.tool-item:active {
  background: var(--primary-color);
}

.tool-icon {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-light);
}

.tool-icon.italic {
  font-style: italic;
}

.tool-icon.underline {
  text-decoration: underline;
}

.tool-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--border-color);
  margin: 0 8rpx;
}

.editor-content {
  min-height: 400rpx;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

/* 保存按钮 */
.btn-group {
  padding: 32rpx 0;
}

/* 覆盖 vant 组件样式 */
.page .van-cell {
  background: transparent !important;
  padding: 28rpx 24rpx !important;
}

.page .van-cell::after {
  border-color: var(--border-light) !important;
}

.page .van-cell__title {
  color: var(--text-secondary) !important;
}

.page .van-field__control {
  color: var(--text-primary) !important;
}

.page .van-field__control::placeholder {
  color: var(--text-muted) !important;
}
