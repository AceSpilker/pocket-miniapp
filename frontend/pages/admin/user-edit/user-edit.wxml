<view class="page theme-{{theme}} page-enter" style="{{cssVars}}" wx:if="{{hasAccess}}">

  <!-- 提示卡片 -->
  <view class="tip-card glass-card fade-in-up" wx:if="{{!isEdit}}">
    <text class="tip-icon">💡</text>
    <text class="tip-text">创建用户后，系统将自动生成密码并发送至用户邮箱</text>
  </view>

  <!-- 表单 -->
  <view class="form-card glass-card fade-in-up" style="animation-delay: 0.1s;">
    <van-cell-group>
      <van-field
        value="{{ username }}"
        label="用户名"
        required
        placeholder="必填"
        disabled="{{isEdit}}"
        bind:change="onUsernameInput"
        custom-class="input-field"
      />
      <van-field
        value="{{ email }}"
        label="邮箱"
        required="{{!isEdit}}"
        placeholder="{{isEdit ? '选填' : '必填，用于接收密码'}}"
        bind:change="onEmailInput"
        custom-class="input-field"
      />
      <van-field
        value="{{ nickname }}"
        label="昵称"
        placeholder="选填"
        bind:change="onNicknameInput"
        custom-class="input-field"
      />
      <van-field
        value="{{ phone }}"
        label="手机号"
        placeholder="选填"
        bind:change="onPhoneInput"
        custom-class="input-field"
      />
      <van-cell title="状态" wx:if="{{isEdit}}">
        <van-switch checked="{{ isActive }}" bind:change="onActiveChange" size="48rpx" active-color="#6366f1" />
      </van-cell>
    </van-cell-group>
  </view>

  <!-- 错误提示 -->
  <van-notice-bar
    wx:if="{{errorMsg}}"
    color="#ef4444"
    background="rgba(239, 68, 68, 0.1)"
    text="{{errorMsg}}"
    wrapable
  />

  <!-- 保存按钮 -->
  <view class="btn-group fade-in-up" style="animation-delay: 0.2s;">
    <van-button
      type="primary"
      block
      round
      loading="{{saving}}"
      bind:click="handleSave"
      custom-class="save-btn"
    >
      {{isEdit ? '💾 保存修改' : '🚀 创建用户'}}
    </van-button>
  </view>
</view>
