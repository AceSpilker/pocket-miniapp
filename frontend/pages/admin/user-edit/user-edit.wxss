/* 用户编辑页 - 炫酷科技风 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: var(--bg-primary);
}

/* 提示卡片 */
.tip-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: rgba(245, 158, 11, 0.1) !important;
  border: 1rpx solid rgba(245, 158, 11, 0.2) !important;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #fbbf24;
  line-height: 1.5;
}

/* 表单卡片 */
.form-card {
  margin-bottom: 24rpx;
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

/* 输入框 */
.form-card .van-field {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-field::after {
  border-bottom: 1rpx solid var(--border-light) !important;
}

.form-card .van-field:last-child::after {
  border-bottom: none !important;
}

.form-card .van-field__label {
  color: var(--text-secondary) !important;
  font-size: 28rpx !important;
  width: auto !important;
  min-width: 120rpx !important;
}

.form-card .van-field__control {
  color: var(--text-primary) !important;
  font-size: 28rpx !important;
}

.form-card .van-field__control::placeholder {
  color: var(--text-muted) !important;
}

/* 禁用状态 */
.form-card .van-field--disabled .van-field__control {
  color: var(--text-muted) !important;
}

/* Cell 样式 */
.form-card .van-cell {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-cell__title {
  color: var(--text-secondary) !important;
}

.form-card .van-cell__value {
  color: var(--text-primary) !important;
}

/* 开关 */
.form-card .van-switch {
  background: var(--border-color) !important;
}

.form-card .van-switch--on {
  background: linear-gradient(135deg, var(--primary-color), #8b5cf6) !important;
}

/* 按钮组 */
.btn-group {
  padding: 32rpx 0;
}

.save-btn {
  background: linear-gradient(135deg, var(--primary-color), #8b5cf6) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 20px var(--border-color) !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
}

/* 错误提示 */
.page .van-notice-bar {
  margin: 0 0 24rpx !important;
  border-radius: 16rpx !important;
}
