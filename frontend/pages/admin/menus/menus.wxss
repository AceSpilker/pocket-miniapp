/* 菜单管理页 - 炫酷科技风 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.total {
  font-size: 26rpx;
  color: #a1a1aa;
}

.create-btn {
  background: linear-gradient(135deg, #06b6d4, #22d3ee) !important;
  border: none !important;
  border-radius: 32rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  font-size: 26rpx !important;
  font-weight: 500 !important;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: #a1a1aa;
}

/* 菜单列表 */
.menu-list {
  margin-top: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(99, 102, 241, 0.15);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.menu-item:active {
  transform: scale(0.98);
  background: rgba(30, 30, 60, 0.8);
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #06b6d4, #22d3ee);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
}

.menu-icon {
  font-size: 40rpx;
}

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.menu-path {
  font-size: 22rpx;
  color: #71717a;
}

.menu-meta {
  margin-left: 16rpx;
}

/* 标签 */
.menu-meta .van-tag {
  font-size: 22rpx !important;
  padding: 6rpx 16rpx !important;
  border-radius: 12rpx !important;
}
