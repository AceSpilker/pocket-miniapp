/* 动态管理页 */

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
}

/* 固定头部区域 */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg-primary);
  padding-top: 16rpx;
}

/* 搜索区 */
.search-section {
  margin: 0 24rpx 16rpx;
  padding: 0;
  background: var(--bg-card) !important;
  border: 1rpx solid var(--border-color) !important;
}

.search-section .van-search {
  padding: 16rpx !important;
}

.search-btn {
  color: var(--primary-light);
  font-weight: 500;
  font-size: 28rpx;
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.stats {
  display: flex;
  align-items: center;
}

.stat-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-right: 24rpx;
}

.create-btn {
  background: linear-gradient(135deg, var(--primary-color), #8b5cf6) !important;
  border: none !important;
  border-radius: 32rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  font-size: 26rpx !important;
  font-weight: 500 !important;
}

/* 可滚动列表区域 */
.scroll-content {
  flex: 1;
  padding-top: 280rpx;
  min-height: 100vh;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
}

/* 动态列表 */
.announcement-list {
  padding: 0 24rpx 60rpx;
}

.announcement-item {
  margin-bottom: 20rpx;
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--border-color);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.item-info {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.item-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.top-tag {
  flex-shrink: 0;
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-muted);
}

.meta-author {
  color: var(--primary-light);
}

.meta-dot {
  margin: 0 8rpx;
}

.meta-time {
  flex: 1;
}

.meta-views {
  margin-left: 16rpx;
}

.item-tags {
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

/* 操作按钮 */
.item-actions {
  display: flex;
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  padding: 20rpx 0;
  transition: all 0.2s ease;
  border-right: 1rpx solid var(--border-light);
}

.action-btn:last-child {
  border-right: none;
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn.top {
  color: #f59e0b;
}

.action-btn.disable {
  color: #f87171;
}

.action-btn.enable {
  color: #10b981;
}

.action-btn.edit {
  color: var(--primary-light);
}

.action-btn.delete {
  color: #f87171;
}
