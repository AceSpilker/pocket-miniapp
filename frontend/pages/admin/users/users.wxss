/* 用户管理页 - 主题适配样式 */

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
}

/* 固定头部区域 */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg-primary);
  padding-top: 16rpx;
}

/* 搜索区 */
.search-section {
  margin: 0 24rpx 16rpx;
  padding: 0;
  background: var(--bg-card) !important;
  border: 1rpx solid var(--border-color) !important;
}

.search-section .van-search {
  padding: 16rpx !important;
}

.search-btn {
  color: var(--primary-light);
  font-weight: 500;
  font-size: 28rpx;
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.total {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.create-btn {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light)) !important;
  border: none !important;
  border-radius: 32rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  font-size: 26rpx !important;
  font-weight: 500 !important;
}

/* 可滚动列表区域 */
.scroll-content {
  flex: 1;
  padding-top: 280rpx;
  min-height: 100vh;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
}

/* 用户列表 */
.user-list {
  padding: 0 24rpx 60rpx;
}

.user-item {
  margin-bottom: 20rpx;
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
  box-shadow: 0 4px 15px var(--shadow-color);
  overflow: hidden;
}

.user-avatar .avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-detail {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.user-account {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 标签 */
.user-info .van-tag {
  font-size: 22rpx !important;
  padding: 6rpx 16rpx !important;
  border-radius: 16rpx !important;
}

/* 操作按钮 */
.user-actions {
  display: flex;
  border-top: 1rpx solid var(--border-light);
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 22rpx 0;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn.edit {
  color: var(--primary-light);
  border-right: 1rpx solid var(--border-light);
}

.action-btn.disable {
  color: var(--warning-color);
  border-right: 1rpx solid var(--border-light);
}

.action-btn.enable {
  color: var(--success-color);
  border-right: 1rpx solid var(--border-light);
}

.action-btn.delete {
  color: var(--danger-color);
}
