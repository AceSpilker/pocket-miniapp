/* 角色编辑页 - 炫酷科技风 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 表单卡片 */
.form-card {
  margin-bottom: 24rpx;
  padding: 0;
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.2);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(99, 102, 241, 0.1);
  background: rgba(236, 72, 153, 0.05);
}

/* 输入框 */
.form-card .van-field {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-field::after {
  border-bottom: 1rpx solid rgba(99, 102, 241, 0.1) !important;
}

.form-card .van-field:last-child::after {
  border-bottom: none !important;
}

.form-card .van-field__label {
  color: #a1a1aa !important;
  font-size: 28rpx !important;
  width: auto !important;
  min-width: 140rpx !important;
}

.form-card .van-field__control {
  color: #fff !important;
  font-size: 28rpx !important;
}

.form-card .van-field__control::placeholder {
  color: #71717a !important;
}

/* 禁用状态 */
.form-card .van-field--disabled .van-field__control {
  color: #71717a !important;
}

/* 权限列表 */
.perm-list {
  padding: 0 24rpx 24rpx;
}

.perm-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(99, 102, 241, 0.1);
  transition: all 0.2s ease;
}

.perm-item:last-child {
  border-bottom: none;
}

.perm-item:active {
  opacity: 0.7;
}

.perm-checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 26rpx;
  color: #fff;
  transition: all 0.2s ease;
  background: transparent;
}

.perm-item.checked .perm-checkbox {
  background: linear-gradient(135deg, #ec4899, #f472b6);
  border-color: transparent;
  box-shadow: 0 4px 15px rgba(236, 72, 153, 0.4);
}

.perm-info {
  flex: 1;
}

.perm-name {
  font-size: 28rpx;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.perm-desc {
  font-size: 22rpx;
  color: #71717a;
}

/* 按钮组 */
.btn-group {
  padding: 24rpx 0;
}

.save-btn {
  background: linear-gradient(135deg, #ec4899, #f472b6) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.4) !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
}

/* 错误提示 */
.page .van-notice-bar {
  margin: 0 0 24rpx !important;
  border-radius: 16rpx !important;
}
