/* 登录页 - 主题适配样式 */

.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-primary);
}

/* 动态背景形状 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: -1;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.5;
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  top: -100rpx;
  right: -100rpx;
  animation: float 8s ease-in-out infinite;
}

.shape-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, var(--secondary-color), #f472b6);
  bottom: 200rpx;
  left: -80rpx;
  animation: float 6s ease-in-out infinite reverse;
}

.shape-3 {
  width: 250rpx;
  height: 250rpx;
  background: linear-gradient(135deg, var(--accent-color), #22d3ee);
  bottom: -50rpx;
  right: 100rpx;
  animation: float 10s ease-in-out infinite;
}

/* 品牌区 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}

.brand-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 0 40px var(--gradient-shape-1);
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.brand-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

/* Tab 切换栏 */
.tab-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 48rpx 32rpx;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border-radius: 48rpx;
  padding: 8rpx;
  border: 1rpx solid var(--border-color);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-muted);
  position: relative;
  transition: all 0.3s ease;
  border-radius: 40rpx;
}

.tab-item.active {
  color: var(--text-primary);
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  font-weight: 500;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--text-primary);
  border-radius: 2rpx;
}

/* 表单卡片 */
.form-card {
  margin: 0 24rpx;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

/* 输入框样式 */
.form-card .van-cell {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-cell::after {
  border-bottom: 1rpx solid var(--border-light) !important;
  left: 24rpx !important;
  right: 24rpx !important;
}

.form-card .van-cell:last-child::after {
  display: none !important;
}

/* 按钮组 */
.btn-group {
  padding: 32rpx 24rpx;
}

/* 登录按钮 */
.form-card .van-button--primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light)) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx !important;
  box-shadow: 0 4px 20px var(--gradient-shape-1) !important;
  height: 96rpx !important;
}

/* 注册链接 */
.register-link {
  text-align: center;
  padding: 8rpx 0 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.link {
  color: var(--primary-light);
  font-weight: 500;
}

/* 微信登录区 */
.wx-login-section {
  padding: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--success-color), #34d399);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 0 30px rgba(16, 185, 129, 0.4);
}

.wx-emoji {
  font-size: 60rpx;
}

.wx-tip {
  text-align: center;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.wx-login-section .van-button--primary {
  background: linear-gradient(135deg, var(--success-color), #059669) !important;
  border: none !important;
  border-radius: 48rpx !important;
  width: 100% !important;
  height: 96rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4) !important;
}

/* 协议 */
.agreement {
  text-align: center;
  padding: 40rpx 0 60rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.agreement .link {
  color: var(--primary-light);
}

/* 语言切换按钮 */
.language-switch {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  backdrop-filter: blur(10px);
  border-radius: 40rpx;
  border: 1rpx solid var(--border-color);
  font-size: 26rpx;
  color: var(--text-primary);
  z-index: 100;
}

.current-lang {
  font-weight: 600;
  color: var(--primary-light);
}

/* 当前语言选项高亮 */
.active-lang {
  color: var(--primary-color) !important;
  font-weight: 600;
}

/* 语言选择器层级和主题适配 */
page {
  --action-sheet-z-index: 9999;
}

.van-action-sheet {
  z-index: 9999 !important;
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__header {
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__content {
  background: var(--bg-secondary) !important;
}

.van-action-sheet__item {
  background: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__item--hover {
  background: var(--card-active-bg) !important;
}

.van-action-sheet__cancel {
  background: var(--bg-glass) !important;
  color: var(--text-primary) !important;
}

.van-action-sheet__subname {
  color: var(--text-muted) !important;
}

.active-lang .van-action-sheet__name {
  color: var(--primary-color) !important;
}
