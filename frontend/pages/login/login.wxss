/* 登录页 - 炫酷科技风 */

.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 动态背景形状 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: -1;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.5;
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  top: -100rpx;
  right: -100rpx;
  animation: float 8s ease-in-out infinite;
}

.shape-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #ec4899, #f472b6);
  bottom: 200rpx;
  left: -80rpx;
  animation: float 6s ease-in-out infinite reverse;
}

.shape-3 {
  width: 250rpx;
  height: 250rpx;
  background: linear-gradient(135deg, #06b6d4, #22d3ee);
  bottom: -50rpx;
  right: 100rpx;
  animation: float 10s ease-in-out infinite;
}

/* 品牌区 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}

.brand-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #ec4899);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 0 40px rgba(99, 102, 241, 0.5);
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.brand-desc {
  font-size: 26rpx;
  color: #a1a1aa;
  letter-spacing: 2rpx;
}

/* Tab 切换栏 */
.tab-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 48rpx 32rpx;
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(10px);
  border-radius: 48rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.2);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #71717a;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 40rpx;
}

.tab-item.active {
  color: #fff;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  font-weight: 500;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

/* 表单卡片 */
.form-card {
  margin: 0 24rpx;
  background: rgba(30, 30, 60, 0.6);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.2);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

/* 输入框样式 */
.form-card .van-cell {
  padding: 28rpx 24rpx !important;
  background: transparent !important;
}

.form-card .van-cell::after {
  border-bottom: 1rpx solid rgba(99, 102, 241, 0.1) !important;
  left: 24rpx !important;
  right: 24rpx !important;
}

.form-card .van-cell:last-child::after {
  display: none !important;
}

/* 按钮组 */
.btn-group {
  padding: 32rpx 24rpx;
}

/* 登录按钮 */
.form-card .van-button--primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
  border: none !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx !important;
  box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4) !important;
  height: 96rpx !important;
}

/* 注册链接 */
.register-link {
  text-align: center;
  padding: 8rpx 0 32rpx;
  font-size: 26rpx;
  color: #a1a1aa;
}

.link {
  color: #818cf8;
  font-weight: 500;
}

/* 微信登录区 */
.wx-login-section {
  padding: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10b981, #34d399);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 0 30px rgba(16, 185, 129, 0.4);
}

.wx-emoji {
  font-size: 60rpx;
}

.wx-tip {
  text-align: center;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  color: #a1a1aa;
}

.wx-login-section .van-button--primary {
  background: linear-gradient(135deg, #10b981, #059669) !important;
  border: none !important;
  border-radius: 48rpx !important;
  width: 100% !important;
  height: 96rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4) !important;
}

/* 协议 */
.agreement {
  text-align: center;
  padding: 40rpx 0 60rpx;
  font-size: 22rpx;
  color: #71717a;
}

.agreement .link {
  color: #818cf8;
}
