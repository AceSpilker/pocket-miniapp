<view class="page page-enter" style="{{cssVars}}">

  <!-- 动态背景 -->
  <view class="bg-shapes">
    <view class="shape shape-1"></view>
  </view>

  <!-- 标题区 -->
  <view class="header fade-in-down">
    <text class="title">💬 {{i18n.texts['feedback.title']}}</text>
    <text class="subtitle">{{i18n.texts['feedback.subtitle']}}</text>
  </view>

  <!-- 反馈列表 -->
  <view class="feedback-list" wx:if="{{list.length > 0}}">
    <view class="feedback-item list-item-anim glass-card tap-scale"
          wx:for="{{list}}"
          wx:key="id"
          style="animation-delay: {{index * 0.08}}s;">
      <view class="feedback-header">
        <text class="feedback-title">{{item.title}}</text>
        <view class="feedback-status status-{{item.status}}">
          {{item.status === 'pending' ? i18n.texts['feedback.statusPending'] : item.status === 'replied' ? i18n.texts['feedback.statusReplied'] : i18n.texts['feedback.statusResolved']}}
        </view>
      </view>
      <view class="feedback-content" wx:if="{{item.content}}">
        {{item.content}}
      </view>

      <!-- 管理员回复 -->
      <view class="admin-reply" wx:if="{{item.admin_reply}}">
        <view class="reply-header">
          <text class="reply-label">📢 {{i18n.texts['feedback.adminReply']}}</text>
          <text class="reply-time">{{item.replied_at}}</text>
        </view>
        <text class="reply-content">{{item.admin_reply}}</text>
      </view>

      <view class="feedback-footer">
        <text class="feedback-time">{{i18n.texts['feedback.updatedAt']}} {{item.updated_at}}</text>
        <view class="feedback-actions">
          <text class="action-btn tap-opacity" catchtap="goEdit" data-id="{{item.id}}" data-title="{{item.title}}">{{i18n.texts['common.edit']}}</text>
          <text class="action-btn danger tap-opacity" catchtap="handleDelete" data-id="{{item.id}}" data-title="{{item.title}}">{{i18n.texts['common.delete']}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state fade-in scale-in" wx:if="{{!loading && list.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">{{i18n.texts['feedback.noData']}}</text>
    <text class="empty-hint">{{i18n.texts['feedback.noDataHint']}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <van-loading size="24rpx" color="var(--primary-color)" />
    <text>{{i18n.texts['common.loading']}}</text>
  </view>

  <!-- 创建按钮 -->
  <view class="create-btn tap-scale pulse-animation" bindtap="goCreate">
    <text>✏️ {{i18n.texts['feedback.submit']}}</text>
  </view>
</view>
