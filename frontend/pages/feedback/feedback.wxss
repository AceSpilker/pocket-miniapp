/* 意见反馈列表页 */

.page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 140rpx;
  position: relative;
}

/* 动态背景 */
.bg-shapes {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.shape-1 {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.2;
  top: -100rpx;
  right: -100rpx;
}

/* 标题区 */
.header {
  padding: 40rpx 24rpx 24rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 反馈列表 */
.feedback-list {
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}

.feedback-item {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-light);
}

.feedback-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.feedback-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-pending {
  background: rgba(245, 158, 11, 0.15);
  color: var(--warning-color);
}

.status-replied {
  background: rgba(99, 102, 241, 0.15);
  color: var(--primary-color);
}

.status-resolved {
  background: rgba(16, 185, 129, 0.15);
  color: var(--success-color);
}

.feedback-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 管理员回复 */
.admin-reply {
  background: var(--card-active-bg);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border-left: 4rpx solid var(--primary-color);
}

.reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.reply-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.reply-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.reply-content {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.feedback-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border-light);
}

.feedback-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.feedback-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 24rpx;
  color: var(--primary-color);
}

.action-btn.danger {
  color: var(--danger-color);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  position: relative;
  z-index: 1;
}

/* 创建按钮 */
.create-btn {
  position: fixed;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
  z-index: 100;
}

.create-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.create-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}
