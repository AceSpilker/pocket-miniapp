/* 自定义 tabBar 样式 - 主题适配 */

.tabbar-container {
  background: var(--tabbar-bg);
  position: relative;
}

/* vant tabbar 样式覆盖 */
.tabbar-container .van-tabbar {
  background: var(--tabbar-bg) !important;
  border-top: none !important;
  height: 120rpx !important;
  padding-top: 16rpx !important;
}

/* 安全区域 */
.tabbar-container .van-tabbar--safe {
  padding-bottom: constant(safe-area-inset-bottom) !important;
  padding-bottom: env(safe-area-inset-bottom) !important;
}

/* tabbar item */
.tabbar-container .van-tabbar-item {
  background: transparent !important;
  padding: 12rpx 0 !important;
}

/* 图标大小 */
.tabbar-container .van-tabbar-item__icon {
  font-size: 48rpx !important;
  margin-bottom: 8rpx !important;
}

/* 文字大小 */
.tabbar-container .van-tabbar-item__text {
  font-size: 24rpx !important;
}
