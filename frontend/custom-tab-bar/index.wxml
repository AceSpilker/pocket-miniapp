<view class="tabbar-container">
  <van-tabbar
    active="{{ active }}"
    bind:change="onChange"
    active-color="#6366f1"
    inactive-color="#71717a"
    safe-area-inset-bottom="{{ true }}"
  >
    <van-tabbar-item icon="home-o">首页</van-tabbar-item>
    <van-tabbar-item icon="user-o">我的</van-tabbar-item>
  </van-tabbar>
</view>
