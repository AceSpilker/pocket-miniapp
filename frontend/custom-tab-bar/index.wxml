<view class="tabbar-container" style="{{cssVars}}">
  <van-tabbar
    active="{{ active }}"
    bind:change="onChange"
    active-color="var(--primary-color)"
    inactive-color="var(--text-muted)"
    safe-area-inset-bottom="{{ true }}"
  >
    <van-tabbar-item icon="home-o">{{i18n.texts['tabbar.home'] || '首页'}}</van-tabbar-item>
    <van-tabbar-item icon="user-o">{{i18n.texts['tabbar.mine'] || '我的'}}</van-tabbar-item>
  </van-tabbar>
</view>
