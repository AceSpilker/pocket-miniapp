# 口袋小程序 后端环境配置
# 复制此文件为 .env 并填入真实值

# 应用
DEBUG=True

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=pocket_miniapp

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 密钥 (生产环境务必更换为随机长字符串)
SECRET_KEY=your-secret-key-change-in-production

# 微信小程序
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret
